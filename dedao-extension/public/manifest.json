{
  "manifest_version": 3,
  "name": "Dedao Ebook Downloader",
  "version": "1.0.0",
  "description": "Download purchased ebooks from Dedao.cn as EPUB",
  "permissions": [
    "cookies",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://*.dedao.cn/*",
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "assets/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.dedao.cn/*"],
      "js": ["assets/content.js"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
